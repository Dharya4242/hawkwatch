# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Phase 1 only — not needed in Phase 3 (fully self-hosted on Kaggle GPU)
GEMMA_API_KEY=your_google_ai_studio_api_key_here

# Phase 1:  GEMMA_ENDPOINT=aistudio            (uses AI Studio API key above)
# Phase 3:  GEMMA_ENDPOINT=https://paddle-probing-march.ngrok-free.dev
#           (rerun Notebook 4 Cell 5 if the tunnel drops — you get a new URL)
#           Phase 3 requires NO API key — 100% self-hosted finetuned model
GEMMA_ENDPOINT=aistudio

# Gemma model ID on AI Studio (Phase 1 only)
GEMMA_MODEL=gemma-4-26b-a4b-it

TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
ALERT_PHONE_NUMBER=+1234567890

DATABASE_URL=sqlite:///./data/incidents.db

# Pipeline config
FRAME_INTERVAL_SECONDS=3
MOTION_THRESHOLD=500
SEVERITY_ALERT_THRESHOLD=CRITICAL
